# Server
PORT=3000

# Snowflake connection
# Account identifier — either the legacy locator (e.g. xy12345.us-east-1)
# or the newer orgname-accountname format
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=svc_college_scorecard_api
SNOWFLAKE_ROLE=college_scorecard_api_reader
SNOWFLAKE_WAREHOUSE=college_scorecard_api_wh
SNOWFLAKE_DATABASE=COLLEGE_SCORECARD_DW
SNOWFLAKE_SCHEMA=RAW

# Absolute path to the PKCS#8 private key (.p8) for key-pair auth
SNOWFLAKE_PRIVATE_KEY_PATH=
